  const[aname,setAname]=useState("");const[apw,setApw]=useState("");
  const[err,setErr]=useState("");const[loading,setLoading]=useState(false);

  async function submitUser(){
    setErr("");setLoading(true);
    if(!name.trim()){setErr("Bitte Name eingeben.");setLoading(false);return;}
    if(!bday){setErr("Bitte Geburtsdatum eingeben.");setLoading(false);return;}
    try{
      const users=await getUsers();
      const key=name.trim().toLowerCase()+"|"+bday;
      if(mode==="register"){
        if(users.some(u=>u.display_name.toLowerCase()===name.trim().toLowerCase())){setErr("Name bereits vergeben.");setLoading(false);return;}
        if(users.find(u=>u.id===key)){setErr("Konto existiert bereits.");setLoading(false);return;}
        await insertUser({id:key,display_name:name.trim(),bday,created_at:nowISO()});
        onLogin({id:key,displayName:name.trim(),bday});
      }else{
        const u=users.find(u=>u.id===key);
        if(!u){setErr("Kein Konto gefunden. Bitte registrieren.");setLoading(false);return;}
        onLogin({id:u.id,displayName:u.display_name,bday:u.bday});
      }
    }catch(e){setErr("Verbindungsfehler: "+e.message);}
    setLoading(false);
  }

  function submitAdmin(){
    setErr("");
    const a=ADMINS.find(a=>a.name.toLowerCase()===aname.trim().toLowerCase()&&a.password===apw);
    if(!a){setErr("Ungültige Zugangsdaten.");return;}
    onAdminLogin(a);
