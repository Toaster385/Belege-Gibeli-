function Toast({msg,onDone}){
  useEffect(()=>{const t=setTimeout(onDone,2500);return()=>clearTimeout(t);},[]);
  return <div style={{position:"fixed",bottom:24,left:"50%",transform:"translateX(-50%)",background:"#000",color:"#fff",padding:"10px 22px",borderRadius:99,fontSize:12,fontFamily:F.mono,zIndex:999,boxShadow:"0 4px 20px #0002",whiteSpace:"nowrap"}}>{msg}</div>;
}

function Badge({label,color}){
  const m={green:{bg:"#e6f4ec",text:"#1a7a3a",border:"#a0d4b0"},yellow:{bg:"#fdf6e3",text:"#b86800",border:"#f5dba0"},gray:{bg:"#f0f0f0",text:"#888",border:"#ddd"}};
  const c=m[color]||m.gray;
  return <span style={{fontSize:10,padding:"2px 9px",borderRadius:99,border:`1px solid ${c.border}`,background:c.bg,color:c.text,fontFamily:F.mono,letterSpacing:.5,whiteSpace:"nowrap"}}>{label}</span>;
}

function FilePreview({src,name}){
  if(!src)return null;
  if(src.startsWith("data:application/pdf"))return <a href={src} download={name} style={{color:"#000",fontSize:12,fontFamily:F.mono,textDecoration:"underline"}}>📄 PDF herunterladen</a>;
  if(src.startsWith("data:text/html")||(name||"").endsWith(".html")){let h="";try{h=atob(src.split(",")[1]);}catch{}return <iframe srcDoc={h} title="Beleg" style={{width:"100%",height:300,border:`1px solid ${C.border}`,borderRadius:6,marginTop:8}} sandbox="allow-same-origin"/>;}
  return <img src={src} alt="Beleg" style={{maxWidth:"100%",maxHeight:200,borderRadius:4,marginTop:8,border:`1px solid ${C.border}`,objectFit:"contain"}}/>;
}

