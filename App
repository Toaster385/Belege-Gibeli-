              ))}
              {selected.file_src&&<div style={{marginTop:10}}><div style={{fontSize:9,color:C.muted,letterSpacing:1.2,marginBottom:6}}>ANHANG</div><FilePreview src={selected.file_src} name={selected.file_name}/></div>}
              <div style={{marginTop:14,display:"flex",flexDirection:"column",gap:7}}>
                <button onClick={()=>toggleVerify(selected.id)} style={{...B(selected.verified?"warn":"ok"),width:"100%",textAlign:"center"}}>{selected.verified?"Verifizierung aufheben":"✓ Als verifiziert markieren"}</button>
                <button onClick={()=>toggleDup(selected.id)} style={{...B("warn"),width:"100%",textAlign:"center"}}>{selected.duplicate?"Duplikat entfernen":"⚠ Als Duplikat markieren"}</button>
                <button onClick={()=>{if(window.confirm("Beleg wirklich löschen?"))handleDelBeleg(selected.id);}} style={{...B("danger"),width:"100%",textAlign:"center"}}>🗑 Löschen</button>
              </div>
            </div>
          )}
        </div>
      )}

      {tab==="users"&&(
        <div style={{maxWidth:620,margin:"0 auto",padding:"0 16px 30px"}}>
          {users.map(u=>{const uB=belege.filter(b=>b.user_id===u.id);return(
            <div key={u.id} style={{background:C.surface,border:`1px solid ${C.border}`,borderRadius:9,padding:"13px 16px",marginBottom:8}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                <div>
                  <div style={{fontSize:13,marginBottom:3}}>{u.display_name}</div>
                  <div style={{fontSize:10,color:C.muted,display:"flex",gap:10,flexWrap:"wrap"}}>
                    <span>Geb. {fmtDate(u.bday)}</span><span>{uB.length} Belege</span>
                    <span>CHF {uB.filter(b=>b.currency==="CHF").reduce((s,b)=>s+(parseFloat(b.amount)||0),0).toFixed(2)}</span>
                    <span>EUR {uB.filter(b=>b.currency==="EUR").reduce((s,b)=>s+(parseFloat(b.amount)||0),0).toFixed(2)}</span>
                  </div>
                </div>
                <button onClick={()=>{if(window.confirm(`Konto von ${u.display_name} löschen?`))handleDelUser(u.id);}} style={{...B("danger"),fontSize:11,padding:"6px 12px"}}>Löschen</button>
              </div>
            </div>
          );})}
        </div>
      )}
      {toast&&<Toast msg={toast} onDone={()=>setToast("")}/>}
    </div>
  );
}

