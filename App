  async function handleDelBeleg(id){await delBeleg(id);setBelege(belege.filter(x=>x.id!==id));setSelected(null);setToast("Beleg gelöscht.");}
  async function handleDelUser(id){await delUser(id);setUsers(users.filter(u=>u.id!==id));setBelege(belege.filter(b=>b.user_id!==id));setToast("Konto gelöscht.");}

  const filtered=belege.filter(b=>{const q=search.toLowerCase();const mQ=!q||b.title.toLowerCase().includes(q)||b.beleg_nr.toLowerCase().includes(q)||b.user_name.toLowerCase().includes(q);const mS=filterStatus==="Alle"||(filterStatus==="Verifiziert"&&b.verified)||(filterStatus==="Ungeprüft"&&!b.verified)||(filterStatus==="Duplikat"&&b.duplicate);return mQ&&mS;}).sort((a,b)=>new Date(b.submitted_at)-new Date(a.submitted_at));
  const stats=[{label:"BELEGE GESAMT",val:belege.length},{label:"UNGEPRÜFT",val:belege.filter(b=>!b.verified).length,warn:belege.filter(b=>!b.verified).length>0},{label:"DUPLIKATE",val:belege.filter(b=>b.duplicate).length,warn:belege.filter(b=>b.duplicate).length>0},{label:"TOTAL CHF",val:"CHF "+belege.filter(b=>b.currency==="CHF").reduce((s,b)=>s+(parseFloat(b.amount)||0),0).toFixed(2)},{label:"TOTAL EUR",val:"EUR "+belege.filter(b=>b.currency==="EUR").reduce((s,b)=>s+(parseFloat(b.amount)||0),0).toFixed(2)}];

  if(loading)return <div style={{display:"flex",alignItems:"center",justifyContent:"center",minHeight:"100vh",fontSize:12,color:C.muted}}>Laden…</div>;

  return(
    <div style={{minHeight:"100vh",background:"#f0f0f0"}}>
      <div style={{background:"#000",padding:"13px 20px",display:"flex",alignItems:"center",justifyContent:"space-between"}}>
        <div style={{fontFamily:F.serif,fontSize:16,fontWeight:900,color:"#fff"}}>🔐 Admin — {admin.name}</div>
        <div style={{display:"flex",gap:8}}>
          <button onClick={refresh} style={{...B("ghost"),fontSize:11,padding:"6px 12px"}}>↻</button>
          <button onClick={onLogout} style={{...B("ghost"),fontSize:11,padding:"6px 12px"}}>ABMELDEN</button>
        </div>
      </div>
      <div style={{background:C.surface,borderBottom:`1px solid ${C.border}`,padding:"0 20px",display:"flex"}}>
        {["belege","users"].map(t=>(
          <button key={t} onClick={()=>{setTab(t);setSelected(null);}} style={{padding:"12px 20px",background:"transparent",border:"none",borderBottom:tab===t?"2px solid #000":"2px solid transparent",cursor:"pointer",fontSize:11,letterSpacing:1,fontFamily:F.mono,color:tab===t?"#000":"#999",fontWeight:tab===t?500:400}}>
            {t==="belege"?"BELEGE":"NUTZERKONTEN"}
          </button>
        ))}
      </div>
      <div style={{maxWidth:900,margin:"0 auto",padding:"18px 16px 0"}}>
        <div style={{display:"flex",gap:10,flexWrap:"wrap",marginBottom:18}}>
          {stats.map(c=>(
            <div key={c.label} style={{flex:"1 1 110px",background:C.surface,border:`1px solid ${c.warn?"#f5dba0":C.border}`,borderRadius:8,padding:"11px 14px"}}>
              <div style={{fontSize:9,color:c.warn?C.warn:C.muted,letterSpacing:1.5,marginBottom:3}}>{c.label}</div>
              <div style={{fontSize:15,fontWeight:500,color:c.warn?C.warn:"#000"}}>{c.val}</div>
            </div>
          ))}
        </div>
      </div>

      {tab==="belege"&&(
        <div style={{maxWidth:900,margin:"0 auto",padding:"0 16px 30px",display:"flex",gap:14}}>
          <div style={{flex:1,minWidth:0}}>
            <div style={{display:"flex",gap:8,marginBottom:12}}>
              <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="Suchen…" style={{...inp,flex:1}}/>
              <select value={filterStatus} onChange={e=>setFilterStatus(e.target.value)} style={{...inp,width:"auto",background:"#fff"}}>
                {["Alle","Ungeprüft","Verifiziert","Duplikat"].map(s=><option key={s}>{s}</option>)}
              </select>
            </div>
            {filtered.map(b=>(
              <div key={b.id} className="hcard" onClick={()=>setSelected(b)} style={{background:C.surface,border:`1px solid ${selected?.id===b.id?"#000":C.border}`,borderRadius:9,padding:"11px 14px",cursor:"pointer",marginBottom:7,transition:"border-color .15s"}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
                  <div style={{flex:1,minWidth:0}}>
                    <div style={{fontSize:12,marginBottom:4,display:"flex",gap:6,flexWrap:"wrap",alignItems:"center"}}>
                      {b.title}{b.verified&&<Badge label="✓" color="green"/>}{b.duplicate&&<Badge label="Duplikat?" color="yellow"/>}
                    </div>
                    <div style={{fontSize:10,color:C.muted,display:"flex",gap:8,flexWrap:"wrap"}}>
                      <span>{b.beleg_nr}</span><span>{b.user_name}</span><span>{fmtDT(b.submitted_at)}</span>
                    </div>
                  </div>
                  <div style={{fontSize:13,fontWeight:500,marginLeft:8,whiteSpace:"nowrap"}}>{fmtAmt(b.amount,b.currency)}</div>
                </div>
              </div>
            ))}
          </div>
          {selected&&(
            <div style={{width:270,background:C.surface,border:`1px solid ${C.border}`,borderRadius:10,padding:"16px",height:"fit-content",position:"sticky",top:16}}>
              <div style={{fontFamily:F.serif,fontSize:15,fontWeight:900,marginBottom:3}}>{selected.title}</div>
              <div style={{fontSize:11,color:C.muted,marginBottom:12}}>{selected.beleg_nr} · {selected.user_name}</div>
              {[{label:"BETRAG",val:fmtAmt(selected.amount,selected.currency)},{label:"DATUM",val:fmtDate(selected.date)},{label:"EINGEREICHT",val:fmtDT(selected.submitted_at)},...(selected.note?[{label:"NOTIZ",val:selected.note}]:[])].map(r=>(
                <div key={r.label} style={{padding:"5px 0",borderBottom:`1px solid ${C.border}`}}>
                  <div style={{fontSize:9,color:C.muted,letterSpacing:1.2,marginBottom:2}}>{r.label}</div>
                  <div style={{fontSize:12}}>{r.val}</div>
