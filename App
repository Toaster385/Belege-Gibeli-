          <div style={{fontFamily:F.serif,fontSize:22,fontWeight:900}}>Belegverwaltung</div>
          <div style={{fontSize:10,color:C.muted,marginTop:4,letterSpacing:1.5}}>DIGITAL · SICHER · ÜBERSICHTLICH</div>
        </div>
        {mode!=="admin"?(
          <>
            <div style={{display:"flex",marginBottom:24,border:`1px solid ${C.border}`,borderRadius:6,overflow:"hidden"}}>
              {["login","register"].map(m=>(
                <button key={m} onClick={()=>{setMode(m);setErr("");}} style={{flex:1,padding:"9px 0",background:mode===m?"#000":"#fff",color:mode===m?"#fff":"#999",border:"none",cursor:"pointer",fontSize:11,letterSpacing:1,fontFamily:F.mono,fontWeight:500}}>
                  {m==="login"?"ANMELDEN":"REGISTRIEREN"}
                </button>
              ))}
            </div>
            <div style={{marginBottom:14}}><label style={lbl}>NAME</label><input style={inp} type="text" value={name} onChange={e=>setName(e.target.value)} onKeyDown={e=>e.key==="Enter"&&submitUser()} placeholder="Vor- und Nachname"/></div>
            <div style={{marginBottom:20}}><label style={lbl}>GEBURTSDATUM</label><input style={inp} type="date" value={bday} onChange={e=>setBday(e.target.value)} onKeyDown={e=>e.key==="Enter"&&submitUser()}/></div>
            {err&&<div style={{color:C.danger,fontSize:12,marginBottom:10}}>{err}</div>}
            <button onClick={submitUser} disabled={loading} style={{...B("primary"),width:"100%",padding:"11px 0",fontSize:12,letterSpacing:1,opacity:loading?.5:1}}>
              {loading?"…":mode==="login"?"ANMELDEN":"KONTO ERSTELLEN"}
            </button>
            <div style={{textAlign:"center",marginTop:20}}>
              <span onClick={()=>{setMode("admin");setErr("");}} style={{fontSize:11,color:C.muted,cursor:"pointer",textDecoration:"underline"}}>Admin-Zugang →</span>
            </div>
          </>
        ):(
          <>
            <div style={{textAlign:"center",marginBottom:20,fontSize:11,color:C.muted,letterSpacing:1}}>ADMIN-BEREICH</div>
            <div style={{marginBottom:14}}><label style={lbl}>ADMIN-NAME</label><input style={inp} type="text" value={aname} onChange={e=>setAname(e.target.value)} onKeyDown={e=>e.key==="Enter"&&submitAdmin()}/></div>
            <div style={{marginBottom:20}}><label style={lbl}>PASSWORT</label><input style={inp} type="password" value={apw} onChange={e=>setApw(e.target.value)} onKeyDown={e=>e.key==="Enter"&&submitAdmin()}/></div>
